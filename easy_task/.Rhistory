library(plotly)
library(DT)
# make sure these aren't empty
nrow(tas_dec_weather)
library(ecotourism)
library(tidyverse)
# recreate tas_dec_weather
tas_dec <- glowworms |>
filter(obs_state == "Tasmania", month == 12)
tas_dec_weather <- tas_dec |>
left_join(weather, by = c("ws_id", "date"))
# now check
nrow(tas_dec)
nrow(tas_dec_weather)
# recreate tas_tourism
tas_region <- glowworms |>
filter(obs_state == "Tasmania") |>
left_join(tourism_region, by = "ws_id")
tas_tourism <- tas_region |>
left_join(tourism_quarterly, by = c("region_id", "ws_id")) |>
filter(!is.na(region))
# recreate purpose_yearly
purpose_yearly <- tas_tourism |>
group_by(year.x, quarter, purpose) |>
summarise(
n_sightings = n(),
avg_trips = mean(trips, na.rm = TRUE),
.groups = "drop"
) |>
filter(!is.na(purpose))
# check
nrow(tas_tourism)
nrow(purpose_yearly)
